rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict "Path-Based Ownership" model for user data and a "Public Read-Only" 
     * model for educational content. Security is enforced by verifying the user's identity via Firebase 
     * Auth and ensuring they only access data within their designated path (/users/{userId}/...).
     *
     * DATA STRUCTURE
     * 1. Static Content: Languages, Topics, Skills, Lessons, and Exercises are organized in a 
     *    deeply nested hierarchy. These are publicly readable to facilitate learning.
     * 2. User Data: All progress, attempts, mastery, and challenges are stored as subcollections 
     *    directly under the specific user's profile document.
     *
     * KEY SECURITY DECISIONS
     * - Authorization Independence: By nesting user data under /users/{userId}, we avoid expensive 
     *   cross-document lookups (get() calls) and ensure that rules remain performant.
     * - Relational Integrity: On creation of user-specific data, we enforce that internal 'userId' 
     *   fields match the URL path parameters.
     * - Prototyping Flexibility: Data types and non-relational fields are not validated to allow 
     *   rapid frontend iteration, but access control is strictly enforced.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow (get) Any user to view a profile. (create/update) The owner to manage their own profile.
     * @deny (write) Any user trying to modify someone else's profile.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Tracks lesson completion status for a specific user.
       * @path /users/{userId}/lessonProgress/{id}
       * @allow (all) The owner of the parent user profile.
       * @deny (all) Any user who is not the owner identified in the path.
       * @principle Path-based ownership for private user data.
       */
      match /lessonProgress/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Records user exercise submissions and AI feedback.
       * @path /users/{userId}/exerciseAttempts/{id}
       * @allow (all) The owner of the parent user profile.
       * @deny (all) Any user who is not the owner identified in the path.
       * @principle Path-based ownership for private user data.
       */
      match /exerciseAttempts/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Stores the user's mastery level for specific skills.
       * @path /users/{userId}/skillMastery/{id}
       * @allow (all) The owner of the parent user profile.
       * @deny (all) Any user who is not the owner identified in the path.
       * @principle Path-based ownership for private user data.
       */
      match /skillMastery/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Personalized coding challenges generated for the user.
       * @path /users/{userId}/aiChallenges/{id}
       * @allow (all) The owner of the parent user profile.
       * @deny (all) Any user who is not the owner identified in the path.
       * @principle Path-based ownership for private user data.
       */
      match /aiChallenges/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global educational content hierarchy.
     * @path /languages/{languageId} (and subcollections)
     * @allow (read) Public access for all users to view content.
     * @deny (write) All users; content is managed by administrators.
     * @principle Public read with restricted writes for static content.
     */
    match /languages/{languageId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      match /topics/{topicId} {
        allow get, list: if true;
        allow create, update, delete: if false;

        match /skills/{skillId} {
          allow get, list: if true;
          allow create, update, delete: if false;

          match /lessons/{lessonId} {
            allow get, list: if true;
            allow create, update, delete: if false;

            match /exercises/{exerciseId} {
              allow get, list: if true;
              allow create, update, delete: if false;
            }
          }
        }
      }
    }

  }
}