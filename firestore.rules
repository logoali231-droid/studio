rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CODE ASCENT SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a strict user-ownership model for personal data and 
     * a public-read model for educational content. The system distinguishes between 
     * global curriculum (Courses, Lessons, Skills) and user-specific interactions 
     * (Attempts, Progress, AI-generated content).
     * 
     * Data Structure:
     * 1. Public Curriculum: Root-level /courses and /skills collections.
     * 2. User Sandbox: All private data is nested under /userProfiles/{userId}.
     * 
     * Key Security Decisions:
     * - User Listing: Prevented at the root /userProfiles level to stop user discovery.
     * - Authorization Independence: User IDs are embedded in paths and documents to allow 
     *   for fast, direct authorization without requiring costly get() lookups.
     * - Structural Segregation: AI-generated exercises are stored in user-specific 
     *   subcollections, while static lesson exercises live within the course hierarchy.
     * 
     * Prototyping Mode:
     * Rules prioritize strict authorization (WHO can access) over strict schema 
     * validation (WHAT the data looks like). Relational integrity is enforced 
     * only for core linking fields like creatorId or userId.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Ensures the document exists and the user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile data. Allows users to manage their own profile.
     * @path /userProfiles/{userId}
     * @allow (create) if auth.uid == userId
     * @deny (list) to prevent user discovery.
     * @principle Ownership (Self-Creation).
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description AI-generated coding exercises unique to a user.
       * @path /userProfiles/{userId}/generatedExercises/{exerciseId}
       * @allow (create) if user is path owner.
       * @principle Structural Segregation (Private vs Public Exercises).
       */
      match /generatedExercises/{exerciseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Records of user exercise attempts.
       * @path /userProfiles/{userId}/exerciseAttempts/{attemptId}
       * @allow (list) only for the owner's own attempts.
       * @principle Relational Integrity (userId must match path).
       */
      match /exerciseAttempts/{attemptId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Tracks mastery levels for skills.
       * @path /userProfiles/{userId}/skillProgress/{skillProgressId}
       * @principle Path-based Ownership.
       */
      match /skillProgress/{skillProgressId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Metadata for AI-generated personalized challenges.
       * @path /userProfiles/{userId}/generatedChallenges/{generatedChallengeId}
       * @principle Authorization Independence.
       */
      match /generatedChallenges/{generatedChallengeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global course catalog. Readable by all students.
     * @path /courses/{courseId}
     * @allow (get, list) if signed in.
     * @deny (write) users cannot modify course content.
     * @principle Public Read with Owner-Only Writes (Admin implied).
     */
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;

      /**
       * @description Lessons within a specific course.
       * @path /courses/{courseId}/lessons/{lessonId}
       */
      match /lessons/{lessonId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if false;

        /**
         * @description Static exercises belonging to a specific lesson.
         * @path /courses/{courseId}/lessons/{lessonId}/exercises/{exerciseId}
         */
        match /exercises/{exerciseId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if false;
        }
      }
    }

    /**
     * @description Global skill tree definitions.
     * @path /skills/{skillId}
     * @allow (get, list) if signed in.
     * @principle Public Read with Owner-Only Writes (Admin implied).
     */
    match /skills/{skillId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}