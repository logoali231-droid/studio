rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CODE ASCENT SECURITY RULES
     *
     * Core Philosophy: This ruleset enforces a strict user-ownership model for all personal progress
     * and activity data, while providing authenticated read access to global educational content.
     *
     * Data Structure: 
     * - User-specific data (Profiles, AI Challenges, Progress, Attempts) is nested under /users/{userId}.
     * - Educational content (Courses, Modules, Exercises, Skills) is top-level and globally readable.
     * - Administrative access is controlled via a dedicated /roles_admin collection.
     *
     * Key Security Decisions:
     * - Structural Segregation: Private user data is strictly separated from public educational content.
     * - Ownership via Path: Authorization for user data is derived directly from the document path, 
     *   ensuring performant list operations and eliminating costly get() lookups.
     * - Admin Elevation: Global content (Courses, Skills) can only be modified by users whose 
     *   UID exists in the /roles_admin collection.
     *
     * Denormalization for Authorization:
     * - User-owned documents contain a 'userId' field that is validated against the document path
     *   on creation and remains immutable on update to ensure relational integrity.
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Combines ownership check with verification that the document exists for updates/deletes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** Checks if the authenticated user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profile. Users can manage their own profile.
     * @path /users/{userId}
     * @allow (create) request.auth.uid == 'user_123' && request.resource.data.id == 'user_123'
     * @deny (update) request.resource.data.id != resource.data.id
     * @principle Restricts access to a user's own data tree and enforces ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Personalized AI Challenges generated for a specific user.
       * @path /users/{userId}/aiChallenges/{aiChallengeId}
       * @allow (get) request.auth.uid == userId
       * @deny (create) request.resource.data.userId != userId
       * @principle Path-based ownership for private personalized content.
       */
      match /aiChallenges/{aiChallengeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User-specific dynamic learning paths.
       * @path /users/{userId}/learningPaths/{learningPathId}
       * @allow (list) request.auth.uid == userId
       * @deny (delete) request.auth.uid != userId
       * @principle Ensures users can only manage their own sequences.
       */
      match /learningPaths/{learningPathId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Tracks mastery level for a specific skill per user.
       * @path /users/{userId}/skillProgress/{skillId}
       * @allow (update) isOwner(userId) && request.resource.data.userId == resource.data.userId
       * @deny (create) request.resource.data.userId != userId
       * @principle Relational integrity: path userId must match document userId.
       */
      match /skillProgress/{skillId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Records of user attempts on exercises or challenges.
       * @path /users/{userId}/exerciseAttempts/{attemptId}
       * @allow (create) isOwner(userId) && request.resource.data.userId == userId
       * @deny (get) request.auth.uid != userId
       * @principle Owner-only access to historical performance data.
       */
      match /exerciseAttempts/{attemptId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global educational courses. Public read, admin write.
     * @path /courses/{courseId}
     * @allow (get) isSignedIn()
     * @deny (create) !isAdmin()
     * @principle Authenticated public read with administrative control for content management.
     */
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Modules within a specific course.
       * @path /courses/{courseId}/modules/{moduleId}
       * @allow (list) isSignedIn()
       * @deny (update) !isAdmin()
       * @principle Content hierarchy follows top-level course permissions.
       */
      match /modules/{moduleId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();

        /**
         * @description Coding exercises within a module.
         * @path /courses/{courseId}/modules/{moduleId}/exercises/{exerciseId}
         * @allow (get) isSignedIn()
         * @deny (delete) !isAdmin()
         * @principle Deeply nested content inherits public read permissions.
         */
        match /exercises/{exerciseId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin();
        }
      }
    }

    /**
     * @description Global definitions of programming skills (The Skill Tree).
     * @path /skills/{skillId}
     * @allow (get) isSignedIn()
     * @deny (update) !isAdmin()
     * @principle Centralized skill definitions are globally readable but admin-managed.
     */
    match /skills/{skillId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative role assignments.
     * @path /roles_admin/{adminUid}
     * @allow (get) isAdmin()
     * @deny (write) true
     * @principle System-level roles are read-only within rules to prevent self-elevation.
     */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}